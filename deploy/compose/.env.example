# =============================================================================
# Configuración de InfraSight - Stack de Docker Compose
# =============================================================================
# Copia este fichero a `.env` y ajusta los valores antes de levantar el stack:
#   cp .env.example .env
# =============================================================================

# -------- Base de datos (TimescaleDB) --------
POSTGRES_USER=infrasight
POSTGRES_PASSWORD=cambia-esto-en-produccion
POSTGRES_DB=infrasight

# -------- Backend (FastAPI) --------
# URL de conexión que usa el backend para hablar con la base de datos.
# Dentro de la red de compose el host es `db`.
DATABASE_URL=postgres://infrasight:cambia-esto-en-produccion@db:5432/infrasight

# Token de enrolamiento compartido. En M1 es estático; en M4 se sustituye
# por tokens de un solo uso emitidos por el dashboard.
ENROLLMENT_TOKEN=enrol-demo-cambia-esto

# Origen permitido para CORS desde el dashboard. Con el setup por defecto
# de compose el dashboard sirve en http://localhost:3000.
CORS_ALLOW_ORIGIN=http://localhost:3000

# -------- Dashboard (Next.js) --------
# URL pública del backend tal y como la verá el navegador.
NEXT_PUBLIC_API_URL=http://localhost:8000

# -------- Agente de demo (ejecutado dentro del stack) --------
# URL del backend desde dentro de la red de compose.
AGENT_API_URL=http://backend:8000
AGENT_HOSTNAME=demo-endpoint
AGENT_COLLECT_INTERVAL_S=15
AGENT_HEARTBEAT_INTERVAL_S=30
